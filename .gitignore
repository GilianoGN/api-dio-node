# Dependências (Nunca envie a node_modules, ela é pesada e gerada pelo npm install)
node_modules/

# Build/Compilação (O código em JS gerado pelo tsc não precisa estar no Git)
build/
dist/

# Banco de Dados Local (No seu caso, o SQLite)
*.sqlite
*.db

# Variáveis de Ambiente (Segurança: senhas e chaves nunca vão para o Git)
.env

# Logs e Cache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# Pastas de IDEs (Opcional, mas limpa o projeto)
.vscode/
.idea/